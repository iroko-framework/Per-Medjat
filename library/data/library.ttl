<https://medjat.irokosociety.org/id/library/9Q425Z48>
  a schema:Book ;
  schema:name "Informal Channels for Conflict Resolution in Ibadan, Nigeria" ;
  schema:url <https://medjat.irokosociety.org/library/?item=9Q425Z48> ;
