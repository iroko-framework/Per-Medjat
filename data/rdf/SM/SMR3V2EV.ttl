<https://medjat.irokosociety.org/id/library/SMR3V2EV>
  a schema:ScholarlyArticle ;
  schema:name "The Modern Slavery (Victim Support Bill): A Cost-Benefit Analysis" ;
  schema:url <https://medjat.irokosociety.org/library/?item=SMR3V2EV> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:SMR3V2EV" ;
  schema:description "This report provides an analysis of the costs and benefits of extending support to adult conclusive victims of human trafficking in England and Wales for 12 months after exiting the National Referral Mechanism (NRM), the UK’s identification and support system for victims of modern slavery. This extended support is proposed under S.48B of The Modern Slavery (Victim Support) Bill (the Bill). The Bill includes provision (S.48A) to guarantee in law the support that is already provided on a non-statutory basis." ;
  schema:author "Andrea Nicholson" ;
  schema:creator "Katarina Schwarz", "Todd Landman", "Arianne Griffith" ;
  schema:datePublished "2019" ;
  schema:publisher "Repository@Nottingham (University of Nottingham)" ;
  schema:sameAs <https://doi.org/10.13140/rg.2.2.10283.59684> ;
  dcterms:identifier "doi:10.13140/rg.2.2.10283.59684" ;
  dcterms:subject "Sex work and related issues" .
