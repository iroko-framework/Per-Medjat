  a schema:ScholarlyArticle ;
  schema:name "European Slave Trading, Abolitionism, and “New Systems Of Slavery” in the Indian Ocean" ;
  schema:url <https://medjat.irokosociety.org/library/?item=WQL8QZSU> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:WQL8QZSU" ;
  schema:description "Recent scholarship on British, Dutch, French, and Portuguese slave trading in the Indian Ocean highlights the need to explore structural connections between pre- and post-emancipation migrant labour systems in the colonial world. Europeans purchased and transported a minimum of 431,000-547,000 slaves of African, Indian, Malagasy, and Southeast Asian origin to destinations in the Indian Ocean world between 1500 and 1850. These data, coupled with recent research on European abolitionist activity in the region and the movement of convict and indentured labourers throughout and beyond this oceanic basin, point to the development of an increasingly integrated global movement of migrant labour during the late eighteenth and early nineteenth centuries." ;
  schema:author "Richard B. Allen" ;
  schema:datePublished "2012" ;
  schema:publisher "PORTAL Journal of Multidisciplinary International Studies" ;
  schema:sameAs <https://doi.org/10.5130/portal.v9i1.2624> ;
  dcterms:identifier "doi:10.5130/portal.v9i1.2624" ;
  dcterms:subject "African history and culture studies", "Colonialism, slavery, and trade", "Global Maritime and Colonial Histories" .
