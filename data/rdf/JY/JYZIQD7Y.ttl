  a schema:Thesis ;
  schema:name "(desde 1919 à Constituição da República de Moçambique de 2004 e à Lei nº 23/2007, de 1 de Agosto)" ;
  schema:url <https://medjat.irokosociety.org/library/?item=JYZIQD7Y> ;
