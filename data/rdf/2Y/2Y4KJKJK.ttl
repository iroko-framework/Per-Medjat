  a schema:ScholarlyArticle ;
  schema:name "Rural pandemic: The afterlives of slavery and colonialism in Costa Chica, Mexico" ;
  schema:url <https://medjat.irokosociety.org/library/?item=2Y4KJKJK> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:2Y4KJKJK" ;
  schema:description "The afterlives of slavery and colonialism have haunted ruralities in the Costa Chica region of Guerrero, Mexico, during the COVID-19 global pandemic. Engaging with rural geographic scholarship, this commentary unpacks how these afterlives have shaped racialised development, negatively impacting the quality of life of Costa Chica’s human and nonhuman life." ;
  schema:author "Ulises Moreno-Tabarez" ;
  schema:datePublished "2020" ;
  schema:publisher "Dialogues in Human Geography" ;
  schema:sameAs <https://doi.org/10.1177/2043820620935681> ;
  dcterms:identifier "doi:10.1177/2043820620935681" ;
  dcterms:subject "Migration and Labor Dynamics", "Rural development and sustainability" .
