  a schema:ScholarlyArticle ;
  schema:name "Factor Endowments, Inequality, and Paths of Development among New World Economies" ;
  schema:url <https://medjat.irokosociety.org/library/?item=TREPA7S4> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:TREPA7S4" ;
  schema:description "Whereas traditional explanations of differences in long-run paths of development across the Americas generally point to the significance of differences in national heritage or religion, we highlight the relevance of stark contrasts in the degree of inequality in wealth, human capital, and political power in accounting for how fundamental economic institutions evolved over time." ;
  schema:author "Stanley L. Engerman" ;
