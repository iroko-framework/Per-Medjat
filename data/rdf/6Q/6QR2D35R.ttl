  a schema:Book ;
  schema:name "Wicked flesh: Black women, intimacy, and freedom in the Atlantic world" ;
  schema:url <https://medjat.irokosociety.org/library/?item=6QR2D35R> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
