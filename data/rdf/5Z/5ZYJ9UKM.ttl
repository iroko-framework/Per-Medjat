  dcterms:identifier "doi:10.1603/0013-8746(2004)097[0647:naadot]2.0.co;2" ;
  dcterms:subject "Amphibian and Reptile Biology", "Animal Behavior and Reproduction", "Animal Vocal Communication and Behavior" .
