<https://medjat.irokosociety.org/id/library/QSRW636E>
  a schema:Thesis ;
  schema:name "Slaves and slavery in Louisiana: the evolution of Atlantic world identities, 1791-1831" ;
  schema:url <https://medjat.irokosociety.org/library/?item=QSRW636E> ;
