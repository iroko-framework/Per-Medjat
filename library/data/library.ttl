<https://medjat.irokosociety.org/id/library/ZCRI5LZQ>
  a schema:Book ;
  schema:name "Urgent archives: Enacting liberatory memory work" ;
  schema:url <https://medjat.irokosociety.org/library/?item=ZCRI5LZQ> ;
