  a schema:Report ;
  schema:name "Geology and mineral deposits of the Gallinas Mountains, Lincoln and Torrance Counties, New Mexico" ;
  schema:url <https://medjat.irokosociety.org/library/?item=DTUG7SRE> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:DTUG7SRE" ;
  schema:description "Rare earth elements (REE) are a group of critical minerals that are essential in most modern electronic devices. In New Mexico, many REE deposits are found in the North American Cordilleran alkaline-igneous belt, a regional zone of Cenozoic alkaline igneous rocks and associated mineral deposits that extends from Canada, through the U.S., and into eastern Mexico. This zone has been explored and exploited for numerous types of mineral deposits, especially gold, silver, fluorite, and REE. The Gallinas Mountains in central New Mexico is one such district with established REE potential. A small amount of bastnsite, a REE fluorocarbonate mineral, was recovered during historic processing for fluorite. In addition to fluorite production, lead, copper, zinc, silver, gold, and iron have been produced from the district." ;
  schema:author "Virginia T. McLemore" ;
