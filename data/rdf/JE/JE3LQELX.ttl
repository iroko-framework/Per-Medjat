  a schema:ScholarlyArticle ;
  schema:name "MAIZE (ZEA MAYS), A PROSPECTIVE MEDICINAL PLANT IN ROMANIA" ;
  schema:url <https://medjat.irokosociety.org/library/?item=JE3LQELX> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:JE3LQELX" ;
  schema:description "Maize, Zea mays L. is considered to be one of the most important cereals cultivated in Romania. The maize has a high hectare production, maize grains have a high nutritional value, but a good capitalization of production, over 56 inquiries in various industries of both grains and corn plants For medicinal purposes from maize plants, stigmas are used the most (Maidis stigmata). These are important for their flavonoid content (0.1-6.3%), saponins (3%), volatile oils (0.2%), calcium and silicate salts, vitamins C, E, K, carbohydrates and allantoin. They have diuretic action, soothing in chronic cystitis and increase bile secretion, help eliminate water from tissues, favor heart disease and obesity." ;
  schema:author "Alexandru Ghețe" ;
  schema:creator "Marcel DUDA", "Dan Vârban", "Rodica Vârban", "Cristina MOLDOVAN", "Sorin Muntean" ;
  schema:datePublished "2019" ;
  schema:publisher "Hop and Medicinal Plants" ;
  schema:sameAs <https://doi.org/10.15835/hpm.v26i1-2.13231> ;
  dcterms:identifier "doi:10.15835/hpm.v26i1-2.13231" ;
  dcterms:subject "Food Science and Nutritional Studies" .
