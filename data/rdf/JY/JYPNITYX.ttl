<https://medjat.irokosociety.org/id/library/JYPNITYX>
  a schema:ScholarlyArticle ;
  schema:name "The Global Lakou World-System" ;
  schema:url <https://medjat.irokosociety.org/library/?item=JYPNITYX> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
  dcterms:identifier "zotero:6479329:JYPNITYX" ;
  schema:description "This work highlights the Haitian sociopolitical economic organization, Lakous, as a form of libertarian communism that must be vertically integrated at the nation-state level so that people can experience total freedom from capitalist relations of production. I conclude the work by extrapolating the lakou system to the world-system level in order to offer it as an alternative to the Protestant capitalist world-system, which threatens all life on earth.&#x0D;" ;
  schema:author "Paul C. Mocombe" ;
  schema:datePublished "2020" ;
  schema:publisher "American International Journal of Social Science Research" ;
  schema:sameAs <https://doi.org/10.46281/aijssr.v5i3.629> ;
  dcterms:identifier "doi:10.46281/aijssr.v5i3.629" ;
  dcterms:subject "Political Economy and Marxism" .
