  a schema:ScholarlyArticle ;
  schema:name "Interview with a Family in Cuajilote: Aurelio Campos Contreras, Juana Maria Contreras Tello, Isidro Campos Mendoza, Alejandro Campos Mendoza, Alejandro Mendoza Montufa, Maricela Campos Mendoza, Maria de los Angeles Campos Contreras / Una Entrevista con una Familia en Cuajilote: Aurelio Campos Contreras, Juana Maria Contreras Tello, Isidro Campos Mendoza, Alejandro Campos Mendoza, Alejandro Mendoza Montufa, Maricela Campos Mendoza, Maria de los Angeles Campos Contreras" ;
  schema:url <https://medjat.irokosociety.org/library/?item=AB7IGDIG> ;
