  a schema:Book ;
  schema:name "Atlantic Creoles in the age of revolutions" ;
  schema:url <https://medjat.irokosociety.org/library/?item=GLPP9GMD> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
