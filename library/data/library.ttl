<https://medjat.irokosociety.org/id/library/6HQ2MI7F>
  a schema:Book ;
  schema:name "Black Atlantic Religion: Tradition, Transnationalism, and Matriarchy in the Afro-Brazilian Candomblé" ;
  schema:url <https://medjat.irokosociety.org/library/?item=6HQ2MI7F> ;
