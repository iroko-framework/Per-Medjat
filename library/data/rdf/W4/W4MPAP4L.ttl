  a schema:ScholarlyArticle ;
  schema:name "Posmrtno oro vo tradiciite na balkanskite Sloveni<br>Posthumous Ritual Dance - <em>Oro</em> - in the Traditions of Balkan Slavs</br>" ;
  schema:url <https://medjat.irokosociety.org/library/?item=W4MPAP4L> ;
  dcterms:isPartOf <https://medjat.irokosociety.org/id/collection/medjat-library> ;
