  a schema:ScholarlyArticle ;
  schema:name "Caribbean Dance from Abakuá to Zouk: How Movement Shapes Identity edited by Susanna Sloat. 2002. Gainesville, FL: University Press of Florida, xx + 408 pp., map, photographs, diagrams, glossary, bibliography, index." ;
  schema:url <https://medjat.irokosociety.org/library/?item=SA3N7TLY> ;
